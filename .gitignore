# ---- Project: runtime / intermediate artifacts -----------------------------
# Load manifest is regenerated by scripts/load_buildings.py.
data/processed/buildings_load_manifest.json

# PDF-export intermediate.
docs/*.html
# Keep Week 4 generated maps tracked.
!docs/map_*.html

# ---- Project: large raw downloads (regeneratable; see data/raw/SOURCES.md)
# DANE MGN full GeoJSON (~261 MB). Reproducible from the ZIP per SOURCES.md.
data/raw/municipios_colombia.geojson

# Microsoft Global Building Footprints — 232 tiles, ~650 MB. Re-fetch with:
#   python scripts/download_buildings.py --ms
data/raw/ms_buildings/*.csv.gz
# MS dataset-links index (~7 MB) is also fetched by the downloader.
data/raw/ms_buildings/dataset-links.csv

# Google Open Buildings — 8 S2 cells, ~2.9 GB. Re-fetch with:
#   python scripts/download_buildings.py --google
data/raw/google_buildings/*_buildings.csv.gz
# Broken/empty tiles.geojson probe artifact.
data/raw/google_buildings/tiles.geojson

# ---- What stays tracked (white-listed via "do not ignore") ----------------
# The small reference files in data/raw/ stay tracked:
#   pdet_municipios.csv, MunicipiosPDET.xlsx, SOURCES.md,
#   municipios_colombia.qmd, google_buildings/score_thresholds.csv
# No rule needed - they don't match anything above.
